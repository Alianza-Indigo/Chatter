# ============================================================================
# Whalabi — Variables de entorno (ejemplo)
# Copia este archivo a `.env` y ajusta los valores.
#   cp .env.example .env
# ============================================================================

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NODE_ENV=development
APP_PUBLIC_URL=http://localhost:3000
API_PORT=4000
WEB_PORT=3000

# Dominio público para el proxy Caddy (HTTPS automático). Ej: chat.tu-org.com
WHALABI_DOMAIN=localhost

# URL pública de la API consumida por el frontend (build-time en Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Base de datos de la app (Postgres de Whalabi, NO el de Synapse)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://whalabi:whalabi@localhost:5433/whalabi?schema=public

# ---------------------------------------------------------------------------
# Matrix (homeserver por defecto / tenant default)
# ---------------------------------------------------------------------------
MATRIX_DEFAULT_HOMESERVER_URL=http://localhost:8008
MATRIX_DEFAULT_SERVER_NAME=whalabi.local
MATRIX_ADMIN_USER=@admin:whalabi.local
MATRIX_ADMIN_PASSWORD=change-me-admin
# Token de registro compartido de Synapse (registration_shared_secret) para provisioning
MATRIX_REGISTRATION_SHARED_SECRET=change-me-registration-secret

# Expuesto al frontend para el tenant default
NEXT_PUBLIC_MATRIX_HOMESERVER_URL=http://localhost:8008
NEXT_PUBLIC_MATRIX_SERVER_NAME=whalabi.local
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=default

# ---------------------------------------------------------------------------
# Bot
# ---------------------------------------------------------------------------
BOT_ENABLED=true
BOT_HOMESERVER_URL=http://localhost:8008
BOT_USER_ID=@whalabi-bot:whalabi.local
BOT_PASSWORD=change-me-bot
# Si se define BOT_ACCESS_TOKEN se usa en vez de password
BOT_ACCESS_TOKEN=
BOT_DISPLAY_NAME=Whalabi Bot
# Si es true, el bot guardará el contenido de los mensajes en logs (por defecto false)
BOT_STORE_CONTENT=false
# Número máximo de respuestas por minuto por room
BOT_RATE_LIMIT_PER_MINUTE=10
# Almacén de estado de sync del bot
BOT_STORAGE_PATH=./.bot-storage

# ---------------------------------------------------------------------------
# LLM (proveedor por defecto; puede sobreescribirse por tenant)
# Valores de LLM_PROVIDER: openai | ollama | dummy
# ---------------------------------------------------------------------------
LLM_PROVIDER=dummy
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Seguridad
# ---------------------------------------------------------------------------
ADMIN_JWT_SECRET=change-me-please-a-long-random-secret
# Token estático para el primer login admin (POST /api/admin/login -> devuelve JWT)
ADMIN_API_TOKEN=change-me-admin-api-token
# Clave para cifrar secretos en reposo (llmApiKey BYOK). Vacía = texto plano (solo dev).
# Genera una con: openssl rand -base64 48
APP_ENCRYPTION_KEY=
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# PWA / Web Push (opcional; generar con `npx web-push generate-vapid-keys`)
# ---------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@whalabi.app
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
