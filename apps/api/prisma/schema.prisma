// Prisma schema para Whalabi.
//
// IMPORTANTE: Whalabi NO almacena mensajes, rooms ni membresías como fuente
// de verdad. Eso vive en Matrix/Synapse. Aquí solo se guarda la configuración
// de producto (tenants, bot, logs operativos y suscripciones push).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LlmProvider {
  openai
  ollama
  dummy
  gemini
}

enum BotResponseMode {
  mention
  dm
  always
}

enum BotLogStatus {
  received
  ignored
  processing
  responded
  rate_limited
  error
}

enum MemberRole {
  owner
  admin
  user
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

/// Una organización dentro de Whalabi, resuelta por dominio público.
model Tenant {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  publicDomain     String          @unique

  // Matrix
  matrixBaseUrl    String
  matrixServerName String

  // Bot
  botUserId        String?
  botEnabled       Boolean         @default(false)
  botSystemPrompt  String?
  botResponseMode  BotResponseMode @default(mention)

  // LLM
  llmProvider      LlmProvider     @default(dummy)
  llmModel         String?
  llmBaseUrl       String?
  /// Clave API del LLM específica del tenant (BYOK). Nunca se expone al frontend.
  llmApiKey        String?

  // Branding
  primaryColor     String          @default("#4f46e5")
  accentColor      String          @default("#a78bfa")
  logoUrl          String?
  tagline          String?

  // Registro
  allowRegistration Boolean        @default(false)

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  botLogs          BotLog[]
  pushSubscriptions PushSubscription[]
  invitations      Invitation[]
  auditLogs        AuditLog[]

  @@index([publicDomain])
  @@index([slug])
}

/// Log operativo del bot. No guarda contenido salvo BOT_STORE_CONTENT=true.
model BotLog {
  id        String       @id @default(cuid())
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  roomId    String
  eventId   String?
  userId    String?
  status    BotLogStatus
  /// Solo presente con opt-in explícito.
  content   String?
  error     String?
  createdAt DateTime     @default(now())

  @@index([tenantId, createdAt])
  @@index([roomId])
}

/// Suscripción Web Push (estructura preparada; envío opcional).
model PushSubscription {
  id        String   @id @default(cuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId  String
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
}

/// Invitación institucional: liga de activación con rol y rooms asignados.
/// El usuario Matrix se crea al aceptar (vía Synapse Admin API).
model Invitation {
  id         String           @id @default(cuid())
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId   String
  email      String
  /// localpart deseado del futuro MXID (@localpart:server).
  localpart  String
  role       MemberRole       @default(user)
  /// Rooms (IDs o alias) a los que se unirá al aceptar.
  roomIds    String[]         @default([])
  /// Token de activación (se envía en la liga; único).
  token      String           @unique
  status     InvitationStatus @default(pending)
  expiresAt  DateTime
  createdBy  String?
  acceptedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([tenantId, status])
  @@index([email])
}

/// Registro de auditoría de acciones administrativas.
model AuditLog {
  id        String   @id @default(cuid())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  tenantId  String?
  /// Quién ejecutó la acción (identificador de admin).
  actor     String
  /// Acción realizada, ej. "tenant.update", "user.create", "invitation.revoke".
  action    String
  /// Objetivo de la acción (id de tenant, MXID de usuario, etc.).
  target    String?
  /// Detalles adicionales no sensibles.
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([action])
}
